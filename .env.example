# AzurDesk AI — Environment Configuration
# Copy this file to .env and fill values before first run.
NODE_ENV=production
PORT=5200
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
DEMO_PASSWORD=admin123

# Optional LLM providers (leave blank to disable)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=

# Ollama / local LLM
OLLAMA_HOST=http://localhost:11434

# Database (SQLite is default; path is relative to project root)
DB_PATH=./data/azurdesk_ai.db
